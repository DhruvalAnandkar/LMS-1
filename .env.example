# ──────────────────────────────────────────────
# LMS Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── App ──
APP_NAME=Lumina
DEBUG=True
API_V1_PREFIX=/api/v1

# ── Database ──
DATABASE_URL=postgresql://lms:lms_password@localhost:5432/lms_db

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Provider ──
# Options: "azure" or "google"
AI_PROVIDER=azure

# ── Azure OpenAI ──
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Google AI (Gemini) ──
GOOGLE_API_KEY=your-google-api-key
GOOGLE_AI_MODEL=gemini-2.0-flash

# ── Pinecone (Vector DB) ──
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=lms-course-content

# ── Storage Mode ──
# When true, use local filesystem storage instead of Azure Blob Storage.
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_PATH=./local_storage

# ── Azure Blob Storage ──
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_DOCUMENTS_CONTAINER=lms-documents
AZURE_STORAGE_SUBMISSIONS_CONTAINER=lms-submissions
AZURE_STORAGE_USE_SAS=true
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60

# ── CORS ──
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Upload Limits ──
MAX_UPLOAD_MB=10
